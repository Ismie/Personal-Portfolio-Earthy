# Kontaktformular — Resend (https://resend.com)
# 1. Account anlegen, API-Key erzeugen, hier eintragen.
# 2. Diese Datei nach .env.local kopieren (wird nicht eingecheckt).
RESEND_API_KEY=

# Empfänger der Kontaktanfragen
CONTACT_TO=romanschulz.kn@gmail.com

# Absender. Für echten Versand eine in Resend verifizierte Domain nutzen,
# z.B. "Roman Schulz <kontakt@romanschulz.com>".
# onboarding@resend.dev funktioniert nur für Tests an die eigene Account-Mail.
CONTACT_FROM=Portfolio <onboarding@resend.dev>
