# Kontaktformular — Resend (https://resend.com)
# 1. Account anlegen, API-Key erzeugen, hier eintragen.
# 2. Diese Datei nach .env.local kopieren (wird nicht eingecheckt).
RESEND_API_KEY=

# Empfänger der Kontaktanfragen
CONTACT_TO=kontakt@romanschulz.com

# Absender. Für echten Versand eine in Resend verifizierte (Sub-)Domain nutzen.
# Empfohlen: Subdomain send.romanschulz.com (isoliert die Versand-Reputation vom
# echten Postfach). Nach Verifizierung z.B.: "Roman Schulz <kontakt@send.romanschulz.com>".
# Bis dahin belassen — onboarding@resend.dev geht nur für Tests an die eigene Account-Mail.
CONTACT_FROM=Roman Schulz <kontakt@romanschulz.com>

# Google Search Console — Verifizierungs-Token (nur der content-Wert aus dem HTML-Meta-Tag).
# Leer lassen, bis eingerichtet; sonst wird das Meta-Tag automatisch gesetzt.
GOOGLE_SITE_VERIFICATION=
